# lobsterbot — environment variables
# Copy this file to .env and fill in your values.

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# InstantlyClaw (OpenClaw) gateway
# GATEWAY_URL: copy from your dashboard at https://app.instantlyclaw.com
# GATEWAY_TOKEN: the Bearer token shown under API / Settings
INSTANTLYCLAW_GATEWAY_URL=
INSTANTLYCLAW_GATEWAY_TOKEN=

# Anthropic API key (optional — only needed if you connect your own LLM key)
# ANTHROPIC_API_KEY=
