# lobsterbot — environment variables
# Copy this file to .env and fill in your values.

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Anthropic API key — forwarded to the URANTiOS bookwriter subprocess
ANTHROPIC_API_KEY=

# Comma-separated Telegram numeric user IDs authorised to run /writebook.
# Leave empty for open mode (every user can write books).
LOBSTER_ALLOWED_USER_IDS=

# Path to the URANTiOS repository (where `python -m bookwriter` lives).
# Defaults to ../URANTiOS if unset.
URANTIOS_REPO=

# Colon-separated vault root directories; books are written into all of them.
# Example:
# BOOKWRITER_VAULTS=/home/user/Obsidian/UrantiaBooks:/home/user/PhD-Triune-Monism/07_Generated_Books
BOOKWRITER_VAULTS=

# When set to "1", run the bookwriter in offline dry-run mode (no API calls).
BOOKWRITER_DRY_RUN=
