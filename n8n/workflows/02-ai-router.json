      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [360, 440]
    },
    {
      "parameters": {
        "rules": { "values": [
          { "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "id": "r1", "leftValue": "={{ $json.task_type }}", "rightValue": "fast", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "fast" },
          { "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "id": "r2", "leftValue": "={{ $json.task_type }}", "rightValue": "creative", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "creative" },
          { "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "id": "r3", "leftValue": "={{ $json.task_type }}", "rightValue": "research", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "research" },
          { "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "id": "r4", "leftValue": "={{ $json.task_type }}", "rightValue": "local", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "local" },
          { "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "id": "r5", "leftValue": "={{ $json.task_type }}", "rightValue": "analysis", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "analysis" },
          { "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "id": "r6", "leftValue": "={{ $json.task_type }}", "rightValue": "search", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "search" }
        ] },
        "options": { "fallbackOutput": "extra" }
      },
