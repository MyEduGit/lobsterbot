      "parameters": { "jsCode": "const body = $input.first().json.body || $input.first().json;\nreturn [{ json: {\n  query: body.query || body.prompt || 'Hello',\n  task_type: (body.task_type || 'code').toLowerCase().trim(),\n  system_prompt: body.system_prompt || ''\n}}];" },
